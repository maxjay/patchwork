{
  "name": "@maxjay/patchwork",
  "version": "0.16.0",
  "description": "A JSON editing engine with base/draft, diff, undo, and scoped lenses.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    },
    "./chat": {
      "import": "./dist/chat.js",
      "types": "./dist/chat.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp.js",
      "types": "./dist/mcp.d.ts"
    },
    "./angular": {
      "import": "./dist/angular.js",
      "types": "./dist/angular.d.ts"
    }
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build",
    "docs:dev": "vitepress dev site",
    "docs:build": "vitepress build site",
    "docs:preview": "vitepress preview site"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxjay/patchwork.git"
  },
  "keywords": [
    "json",
    "editor",
    "diff",
    "undo",
    "jsonpath",
    "draft"
  ],
  "author": "Max <maxjay2000@gmail.com>",
  "contributors": [
    {
      "name": "Hanqi Zhou",
      "email": "hz645@cornell.edu",
      "url": "https://github.com/hanqi-zhou"
    },
    {
      "name": "Beth Grant",
      "email": "bethgrant@live.co.uk",
      "url": "https://github.com/bethGrant"
    },
    {
      "name": "George Wright",
      "email": "wrightgeorge42@gmail.com",
      "url": "https://github.com/wrightg42"
    }
  ],
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/maxjay/patchwork/issues"
  },
  "homepage": "https://github.com/maxjay/patchwork#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@angular/core": "^21.2.14",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@types/node": "^25.6.0",
    "codemirror": "^6.0.2",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "jsonpath-rfc9535": "^1.3.0"
  }
}
