{
  "name": "@maxjay/patchwork",
  "version": "0.8.0",
  "description": "A JSON editing engine with base/draft, diff, undo, and scoped lenses.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    },
    "./chat": {
      "import": "./dist/chat.js",
      "types": "./dist/chat.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp.js",
      "types": "./dist/mcp.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxjay/patchwork.git"
  },
  "keywords": [
    "json",
    "editor",
    "diff",
    "undo",
    "jsonpath",
    "draft"
  ],
  "author": "Max <maxjay2000@gmail.com>",
  "contributors": [
    { "name": "Hanqi Zhou", "email": "hz645@cornell.edu", "url": "https://github.com/hanqi-zhou" },
    { "name": "Beth Grant", "email": "bethgrant@live.co.uk", "url": "https://github.com/bethGrant" },
    { "name": "George Wright", "email": "wrightgeorge42@gmail.com", "url": "https://github.com/wrightg42" }
  ],
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/maxjay/patchwork/issues"
  },
  "homepage": "https://github.com/maxjay/patchwork#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "jsonpath-rfc9535": "^1.3.0"
  }
}
